{
    "name": "sendkit/sendkit-php",
    "description": "PHP SDK for the SendKit email API",
    "keywords": ["sendkit", "email", "api", "sdk"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "SendKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SendKit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
